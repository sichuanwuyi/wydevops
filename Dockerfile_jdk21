# =================================================================
# STAGE 1: Base Image and System Setup
# =================================================================
FROM maven:4.0.0-rc-5-eclipse-temurin-21-noble

LABEL org.opencontainers.image.authors="wuyi <11372349@qq.com>"

# Install system dependencies, git, and Docker CLI in a single layer for efficiency.
# This follows best practices: update, install, and clean up in one RUN command.
RUN apt-get update && \
    apt-get install -y git ca-certificates curl libxml2-utils && \
    # Add Docker's official GPG key
    install -m 0755 -d /etc/apt/keyrings && \
    curl -fsSL https://download.docker.com/linux/ubuntu/gpg -o /etc/apt/keyrings/docker.asc && \
    chmod a+r /etc/apt/keyrings/docker.asc && \
    # Set up the Docker repository
    echo "deb [arch=$(dpkg --print-architecture) signed-by=/etc/apt/keyrings/docker.asc] https://download.docker.com/linux/ubuntu $(. /etc/os-release && echo "$VERSION_CODENAME") stable" | tee /etc/apt/sources.list.d/docker.list > /dev/null && \
    # Update apt with the new repo and install Docker CLI
    apt-get update && \
    apt-get install -y docker-ce-cli && \
    # Clean up apt cache to reduce image size
    rm -rf /var/lib/apt/lists/*

# =================================================================
# STAGE 2: Environment and User Configuration
# =================================================================
# Set environment variables for the application.
ENV DEBIAN_FRONTEND=noninteractive \
    WYDEVOPS_WORK_MODE=local \
    WYDEVOPS_LOG_LANGUAGE=en \
    WYDEVOPS_HOME=/home/tmt/.wydevops \
    TARGET_PROJECT_HOME=/home/tmt/project \
    DOCKER_REPO_CONFIG="" \
    CHART_REPO_CONFIG="" \
    IMAGE_LOCAL_CACHE_DIR=/home/tmt/cachedImages \
    ENABLE_CLEAR_CACHED_PARAMS=true \
    ENABLE_DEBUG=false \
    ENABLE_NOTIFY=true \
    ENABLE_FORCE_COVERAGE=true \
    ENABLE_REMOVE_IMAGE=true \
    SHOW_HELP=false \
    SHOW_VERSION=false \
    GIT_REPO_URL=https://gitee.com/tmt_china/wydevops.git \
    GIT_BRANCH=develop

# ARG to receive the host's docker group GID for docker.sock access.
# Pass this during build: --build-arg DOCKER_GID=$(getent group docker | cut -d: -f3)
ARG DOCKER_GID=999

# Create a dedicated user and group for the application.
# Also, create a 'docker' group with the host's GID and add the user to it.
RUN groupadd --gid 1001 tmt && \
    groupadd --gid ${DOCKER_GID} docker && \
    useradd --uid 1001 --gid tmt --groups docker -m -s /bin/bash tmt

# =================================================================
# STAGE 3: Application Setup (as non-root user)
# =================================================================
# Switch to the non-root user.
USER tmt
WORKDIR ${WYDEVOPS_HOME}

COPY --chown=tmt:tmt ./wydevops-update.sh ${WYDEVOPS_HOME}/
COPY --chown=tmt:tmt ./client-config.yaml ${WYDEVOPS_HOME}/

# set executable permissions, all in a single RUN command.
RUN chmod +x ${WYDEVOPS_HOME}/wydevops-update.sh

# =================================================================
# STAGE 4: Container Execution
# =================================================================
# Set the entrypoint to the main execution script.
ENTRYPOINT ["/bin/sh", "-c", "${WYDEVOPS_HOME}/wydevops/wydevops-update.sh"]

# Set the default command-line arguments for the entrypoint.
CMD ["-A", "linux/amd64", "-O", "linux/amd64", "-B", "single", "-S", "build,docker,chart,package,deploy"]
